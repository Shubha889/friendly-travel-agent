---
config:
  flowchart:
    curve: linear
---
graph TD
    START([Start])
    INTENT[Detect Intent]
    GREETING[Greeting]
    GENERAL[General Travel Question]
    CHECK_MISSING[Check Missing Info]
    CLARIFY[Ask Clarification]
    MODIFICATION[Handle Modification]
    FLIGHT[Flight Agent]
    HOTEL[Hotel Agent]
    CONFIRM_FLIGHT[Confirm Flight]
    CONFIRM_HOTEL[Confirm Hotel]
    AGGREGATE[Aggregate Results]
    END([End])

    START --> INTENT
    INTENT --> GREETING
    GREETING --> GENERAL
    GENERAL --> CHECK_MISSING
    CHECK_MISSING --> CLARIFY
    CLARIFY --> MODIFICATION
    MODIFICATION -.-> FLIGHT
    MODIFICATION -.-> HOTEL
    MODIFICATION -.-> AGGREGATE
    MODIFICATION -.-> END
    FLIGHT -.-> AGGREGATE
    FLIGHT -.-> HOTEL
    HOTEL --> AGGREGATE
    AGGREGATE --> END

    classDef default fill:#f2f0ff,line-height:1.2
    classDef first fill-opacity:0
    classDef last fill:#bfb6fc
